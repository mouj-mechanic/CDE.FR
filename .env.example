# ===========================================
# TryWithAI — environment variables (MVP)
# ===========================================
# Copy this file to .env.local (which is GIT-IGNORED) and fill in your keys.
# NEVER commit .env.local. NEVER prefix any secret with NEXT_PUBLIC_*.

# ─── AI provider routing ────────────────────────────────────────────
# - "mock"   : local placeholder image (default if empty)
# - "openai" : OpenAI GPT Image (gpt-image-1 by default) for try-on edits
#               • final result must come from OpenAI for every category
#               • requires OPENAI_API_KEY (the route returns 500 if missing)
# - "fal"    : fal.ai → FLUX Kontext / FLUX Fill / FASHN
#               • requires FAL_KEY (the route returns 500 if missing)
# - "auto"   : "openai" if OPENAI_API_KEY is set, else "fal" if FAL_KEY,
#               otherwise "mock"
AI_TRYON_PROVIDER=openai

# Mirrored to the client to display "Mode démo" vs "Généré avec GPT Image"
# in PrivacyNote / ResultView. Set to the same value as AI_TRYON_PROVIDER.
NEXT_PUBLIC_AI_PROVIDER=openai

# ─── OpenAI credentials & options ───────────────────────────────────
# https://platform.openai.com/api-keys — server-side only.
# NEVER expose to the browser. NEVER create NEXT_PUBLIC_OPENAI_API_KEY.
OPENAI_API_KEY=

# Defaults: gpt-image-1 / auto / high quality / masked edits enabled.
# When OpenAI ships gpt-image-2, just change this var, no code change.
OPENAI_IMAGE_MODEL=gpt-image-1
# "auto" picks the closest 1024-class size from the user-photo aspect
# ratio (1024x1024 / 1024x1536 / 1536x1024). Override to force one.
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=high

# gpt-image-1: forces PNG output so alpha edges around the product /
# hair / accessories survive (no JPEG ringing artefacts).
OPENAI_IMAGE_OUTPUT_FORMAT=png

# gpt-image-1 only. `high` tells the model to stick close to the input
# pixels — critical for accessory try-on where the composite already
# places the product in the right spot. Use `low` if you want the
# model to take more creative liberties (not recommended for e-commerce).
OPENAI_INPUT_FIDELITY=high

# Global on/off for masked editing.
OPENAI_USE_MASKED_EDIT=true

# The customer NEVER provides a mask. The app auto-generates one from
# the deterministic composite (browser pipeline → MediaPipe placement +
# silhouette + Gaussian feather). Keep this flag at the recommended
# value below unless you're running an isolated test where you want the
# route to call OpenAI with a customer-supplied mask (rare).
REQUIRE_MASK_FOR_OPENAI=false

# Mirror REQUIRE_MASK_FOR_OPENAI to the client. NEVER set OPENAI_API_KEY
# as NEXT_PUBLIC_*; only lightweight boolean flags are safe to expose.
NEXT_PUBLIC_REQUIRE_MASK_FOR_OPENAI=false

# ─── Automatic mask + accessory strict mode ─────────────────────────
# OPENAI_AUTO_MASK: when on, the route will derive a contact-band mask
# from the composite + user-image diff if the client didn't ship one.
# This is the safety net for the "the customer never provides a mask"
# guarantee — leave it on.
OPENAI_AUTO_MASK=true
# REQUIRE_INTERNAL_MASK_FOR_ACCESSORIES: when on, an accessory try-on
# without composite+mask falls back to the deterministic composite
# (or 400 if no composite reached the route). It NEVER calls OpenAI in
# a free-generation mode for accessories — that would let the model
# replace the product / alter the customer.
REQUIRE_INTERNAL_MASK_FOR_ACCESSORIES=true
# TRYON_ACCESSORY_STRICT_MODE: master switch for the strict accessory
# pipeline. Disable only to allow legacy/free-generation behaviour.
TRYON_ACCESSORY_STRICT_MODE=true
# TRYON_FALLBACK_TO_DETERMINISTIC: when on, accessory results that fail
# the post-generation product fidelity check (dominant colour shift,
# silhouette drift) fall back to the deterministic composite so the
# product is pixel-perfect even if shadows are less refined.
TRYON_FALLBACK_TO_DETERMINISTIC=true
# DISABLE_FREE_GENERATION_FOR_ACCESSORIES: when on, OpenAI is *not*
# called for accessories without composite+mask. The deterministic
# composite is returned instead with a `auto_mask_failed_fallback_used`
# warning.
DISABLE_FREE_GENERATION_FOR_ACCESSORIES=true
# REQUIRE_CLIENT_MASK: deliberately kept at false. The client never
# provides a mask in production.
REQUIRE_CLIENT_MASK=false

# When true, the browser logs the deterministic pipeline artefacts
# (composite + mask + placement) to the console so engineers can spot
# wrong scale / rotation. Customers never see anything. Keep false in
# production builds.
TRYON_DEBUG_LAYERS=false

# Outside-mask preservation threshold. After every OpenAI edit we
# compare the preserved area between the original base image and the
# result. score >= threshold ⇒ outsideMaskPreserved=true.
# 0.92 is a sensible default; lower it (e.g. 0.88) if the model is
# rejected too often, raise it (e.g. 0.95) for stricter QA.
OPENAI_PRESERVATION_THRESHOLD=0.92

# Strict customer preservation: when on AND in API-only mode AND a mask
# was used, the route refuses results whose outside-mask score is below
# OPENAI_PRESERVATION_THRESHOLD (returns 502 with "Use a tighter
# mask"). Set to "false" to downgrade to a soft warning.
OPENAI_PRESERVE_CUSTOMER_STRICT=true

# Product-lock pipeline (accessories only).
# When on, the route re-stamps the original transparent product PNG on
# top of the OpenAI edit so dial / frame / stones / metal stay 1:1
# with the reference. Requires the client to send a composite + mask.
# Clothes are always excluded from this pipeline.
OPENAI_PRODUCT_LOCK=true

# Optional tuning: pixel difference threshold (0..255) used by the
# lock pipeline to detect the product silhouette in the composite.
# Default 18. Raise it (e.g. 30) if the silhouette spills into skin
# shadows; lower it (e.g. 10) for more aggressive masking.
# OPENAI_PRODUCT_LOCK_DIFF_THRESHOLD=18

# Per-category mask flags. Each defaults to true unless explicitly set
# to "false". Lets operators disable masked editing for one category
# without rebuilding.
WATCH_USE_MASKED_EDIT=true
GLASSES_USE_MASKED_EDIT=true
HEADWEAR_USE_MASKED_EDIT=true
HAND_JEWELRY_USE_MASKED_EDIT=true
CLOTHES_USE_MASKED_EDIT=true

# ─── API-only mode (recommended with provider=openai) ───────────────
# When *any* of these is true, the route NEVER returns a locally rendered
# image (fast-overlay, canvas composite, mock) as the final result. If
# OpenAI fails the response is an error JSON, not a fallback. Critical
# for proving the result is generated by OpenAI in QA / debug.
TRYON_RENDER_MODE=api-only
DISABLE_LOCAL_RENDER=true

# ─── fal.ai (legacy / optional) ─────────────────────────────────────
FAL_KEY=

# Optional dedicated key for FASHN if you ever integrate it outside fal.
FASHN_API_KEY=

# Legacy generic fallback key (still accepted as FAL_KEY).
AI_TRYON_API_KEY=

# ===========================================
# Example — strict OpenAI mode (recommended)
# ===========================================
#
#   AI_TRYON_PROVIDER=openai
#   NEXT_PUBLIC_AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-proj-xxxxxxxx
#   TRYON_RENDER_MODE=api-only
#   DISABLE_LOCAL_RENDER=true
#
# Verify:  http://localhost:3000/api/ai-status
# Expect:  { ok: true, hasOpenAIKey: true, mode: "real-ai-openai", ... }
