# ===========================================
# TryWithAI — environment variables (MVP)
# ===========================================

# AI provider routing
# ---------------------------------------------
# - "mock"  : local placeholder image (default if empty)
# - "fal"   : fal.ai → FLUX Kontext for accessories, FASHN for clothes
# - "auto"  : "fal" if FAL_KEY is present, otherwise "mock"
AI_TRYON_PROVIDER=mock

# fal.ai credentials (https://fal.ai/dashboard/keys)
FAL_KEY=

# Optional dedicated key for FASHN if you ever integrate it outside fal.
FASHN_API_KEY=

# Legacy generic fallback key (still accepted for backwards compat).
AI_TRYON_API_KEY=

# Exposed to the client to display "Mode démo" vs "Généré avec IA"
# in PrivacyNote / ResultView. Set to the same value as AI_TRYON_PROVIDER.
NEXT_PUBLIC_AI_PROVIDER=mock
