# ===========================================
# TryWithAI — environment variables (MVP)
# ===========================================
# Copy this file to .env.local (which is GIT-IGNORED) and fill in your keys.
# NEVER commit .env.local. NEVER prefix any secret with NEXT_PUBLIC_*.

# AI provider routing
# ---------------------------------------------
# - "mock"   : local placeholder image (default if empty)
# - "openai" : OpenAI GPT Image (gpt-image-1) for try-on edits
#               (requires OPENAI_API_KEY — throws an explicit error if missing)
# - "fal"    : fal.ai → FLUX Kontext / FLUX Fill / FASHN
#               (requires FAL_KEY — throws an explicit error if missing)
# - "auto"   : "openai" if OPENAI_API_KEY is set, else "fal" if FAL_KEY is set,
#               otherwise "mock"
AI_TRYON_PROVIDER=mock

# OpenAI credentials & options (https://platform.openai.com/api-keys)
# Server-side only. NEVER expose these to the browser.
OPENAI_API_KEY=
# Defaults: gpt-image-1 / 1024x1024 / high quality / masked edits enabled.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_USE_MASKED_EDIT=true

# fal.ai credentials (https://fal.ai/dashboard/keys)
# Server-side only. NEVER expose this to the browser.
FAL_KEY=

# Optional dedicated key for FASHN if you ever integrate it outside fal.
FASHN_API_KEY=

# Legacy generic fallback key (still accepted for backwards compat).
AI_TRYON_API_KEY=

# Exposed to the client to display "Mode démo" vs "Généré avec IA"
# in PrivacyNote / ResultView. Set to the same value as AI_TRYON_PROVIDER.
NEXT_PUBLIC_AI_PROVIDER=mock

# Render pipeline (overlay first vs AI first)
# ---------------------------------------------
# - "auto"    : accessory categories use fast deterministic overlay (MediaPipe
#                + canvas, zero AI cost); clothes uses specialized VTON.
# - "fast"    : force fast overlay for every accessory category.
# - "premium" : force AI generation (more expensive, more hallucinations).
TRYON_RENDER_MODE=auto

# ===========================================
# Example — real OpenAI generation (local)
# ===========================================
# Create .env.local with:
#
#   AI_TRYON_PROVIDER=openai
#   OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx
#   NEXT_PUBLIC_AI_PROVIDER=openai
#
# Then `npm run dev` and verify:  http://localhost:3000/api/ai-status
# Expected: { ok: true, hasOpenAIKey: true, mode: "real-ai-openai" }

# ===========================================
# Example — real fal.ai generation (local)
# ===========================================
# Create .env.local with:
#
#   AI_TRYON_PROVIDER=fal
#   FAL_KEY=your_fal_key_here
#   NEXT_PUBLIC_AI_PROVIDER=fal
#
# Then `npm run dev` and verify:  http://localhost:3000/api/ai-status
# Expected: { ok: true, hasFalKey: true, mode: "real-ai-fal" }
